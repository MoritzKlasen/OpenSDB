# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_client_id
ALLOWED_GUILD_ID=your_discord_guild_id

# Admin Panel Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
# Optional: provide a pre-hashed bcrypt password instead of plaintext
# ADMIN_PASSWORD_HASH=$2b$10$...

# Metrics Basic Auth
METRICS_BASIC_USER=metrics
METRICS_BASIC_PASS=change_me

# Server Configuration
ADMIN_UI_PORT=8001
NODE_ENV=production

# Database
DB_URI=mongodb://mongo:27017/botdb

# Security
JWT_SECRET=generate_a_random_64_char_secret
INTERNAL_SECRET=generate_another_random_64_char_secret
CORS_ORIGINS=https://yourdomain.com

# Optional
# SERVER_TIMEZONE=UTC
